<div class="hero-section">
  <nav class="navbar">
    <div class="nav-logo">
      <%= image_tag "logo.png", alt: "RideU", height: 32 %>
    </div>

    <div class="nav-links">
      <%= link_to "Buscar Viaje", trips_path, class: "nav-link active" %>
      <%= link_to "Publicar Ruta", new_trip_path, class: "nav-link" %>
      <%= link_to "Mi Perfil", profile_path, class: "nav-link" %>

      <% if user_signed_in? %>
        <%= link_to "Cerrar sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-btn" %>
      <% else %>
        <%= link_to "Ingresar", new_user_session_path, class: "nav-btn" %>
      <% end %>
    </div>
  </nav>

  <div class="hero-content">
    <div class="hero-text">
      <h1>Conecta tu camino<br><span>con otros estudiantes</span></h1>
      <p><strong>Comparte tus viajes</strong> y llega a la universidad de forma fácil y segura.</p>

      <div class="hero-btns">
        <%= link_to "Buscar Viaje", trips_path, class: "btn-primary" %>
        <%= link_to "Publicar Ruta", new_trip_path, class: "btn-outline" %>
      </div>
    </div>

    <div class="hero-illustration">
      <%= image_tag "hero.png", alt: "RideU ilustración" %>
    </div>
  </div>

  <div class="hero-wave">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,20 C360,60 1080,60 1440,20 L1440,60 L0,60 Z" fill="#ffffff"/>
    </svg>
  </div>
</div>

<div class="main-section">
  <div class="search-panel">
    <h3>Encuentra un Viaje</h3>
    <input type="text" class="search-select" placeholder="🔍 Origen (ej: Chicureo)">
    <input type="text" class="search-select" placeholder="🏫 Destino (ej: Campus PUC)">
    <input type="time" class="search-select">
    <button class="btn-buscar">Buscar</button>
  </div>

  <div class="trips-panel">
    <h3>Oferta de Viajes</h3>

    <div class="trips-grid">
      <% if @trips&.any? %>
        <% @trips.each do |trip| %>
          <div class="trip-card">
            <div class="trip-header">
              <div class="trip-avatar">
                <%= trip.user.email.first.upcase %>
              </div>

              <div>
                <p class="trip-name">
                  <%= trip.user.email.split("@").first.capitalize %>
                </p>
                <p class="trip-route">
                  <%= trip.origin %> → <%= trip.destination %>
                </p>
              </div>
            </div>

            <div class="trip-footer">
              <span class="trip-price">
                $ <%= number_with_delimiter(trip.price, delimiter: ".") %>
                <span class="trip-spots">· <%= trip.available_seats %> cupos</span>
              </span>

              <% if trip.available_seats > 0 %>
                <%= link_to "Ver viaje", trip_path(trip), class: "btn-solicitar" %>
              <% else %>
                <span class="full-badge">LLENO</span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div style="grid-column: span 2; text-align:center; padding: 40px; color: #888;">
          <p style="font-size:16px; margin-bottom:16px;">🚗 No hay viajes disponibles aún.</p>
          <%= link_to "Publicar el primero", new_trip_path, class: "btn-solicitar" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="stats-bar">
  <div class="stat-item">
    <p class="stat-label">✓ Viajes Completados</p>
    <p class="stat-value">12.500 +</p>
  </div>

  <div class="stat-item">
    <p class="stat-label">🌿 CO₂ Ahorrado</p>
    <p class="stat-value">8.2 Ton</p>
  </div>

  <div class="stat-item">
    <p class="stat-label">🐷 Promedio Ahorrado</p>
    <p class="stat-value">$ 38.000 CLP</p>
  </div>
</div>