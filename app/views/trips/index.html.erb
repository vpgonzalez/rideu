<div class="page-container">
  <div class="page-header">
    <nav class="navbar">
      <div class="nav-logo">
        <%= image_tag "logo.png", alt: "RideU" %>
      </div>

      <div class="nav-links">
        <%= link_to "Buscar Viaje", trips_path, class: "nav-link active" %>
        <%= link_to "Publicar Ruta", new_trip_path, class: "nav-link" %>
        <%= link_to "Mi Perfil", profile_path, class: "nav-link" %>

        <% if user_signed_in? %>
          <%= link_to "Cerrar sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-btn" %>
        <% else %>
          <%= link_to "Ingresar", new_user_session_path, class: "nav-btn" %>
        <% end %>
      </div>
    </nav>
  </div>

  <div class="trips-index-container">
    <div class="trips-index-sidebar">
      <h3>Filtrar Viajes</h3>
      <input type="text" class="search-select" placeholder="🏫 Universidad">
      <input type="text" class="search-select" placeholder="🔍 Origen">
      <input type="time" class="search-select">
      <button class="btn-buscar">Filtrar</button>
    </div>

    <div class="trips-index-main">
      <div class="trips-index-header">
        <h2>Viajes Disponibles</h2>
        <%= link_to "＋ Publicar mi ruta", new_trip_path, class: "btn-solicitar" %>
      </div>

      <% if @trips.empty? %>
        <div class="trips-empty">
          <p>🚗 No hay viajes disponibles por ahora.</p>
          <%= link_to "Publicar el primero", new_trip_path, class: "btn-auth" %>
        </div>
      <% else %>
        <div class="trips-index-grid">
          <% @trips.each do |trip| %>
            <div class="trip-card">
              <div class="trip-header">
                <div class="trip-avatar">
                  <%= trip.user.email.first.upcase %>
                </div>

                <div>
                  <p class="trip-name">
                    <%= trip.user.respond_to?(:full_name) ? trip.user.full_name : trip.user.email.split("@").first.capitalize %>
                  </p>
                  <p class="trip-route"><%= trip.origin %> → <%= trip.destination %></p>
                </div>
              </div>

              <div class="trip-info-row">
                <span>🕐 <%= trip.departure_time.strftime("%H:%M") %></span>

                <% if trip.available_seats > 0 %>
                  <span>💺 <%= trip.available_seats %> cupos</span>
                <% else %>
                  <span class="full-badge">LLENO</span>
                <% end %>
              </div>

              <div class="trip-footer">
                <span class="trip-price">
                  $ <%= number_with_delimiter(trip.price, delimiter: ".") %>
                  <span class="trip-spots">· <%= trip.available_seats %> cupos</span>
                </span>

                <div class="trip-actions">
                  <%= link_to "Ver viaje", trip_path(trip), class: "btn-solicitar" %>

                  <% if user_signed_in? && current_user != trip.user && trip.available_seats > 0 %>
                    <%= button_to "Reservar",
                        trip_reservations_path(trip),
                        method: :post,
                        class: "btn-solicitar" %>
                  <% elsif user_signed_in? && current_user == trip.user %>
                    <span class="own-trip-label">Tu viaje</span>
                  <% elsif trip.available_seats <= 0 %>
                    <span class="full-badge">LLENO</span>
                  <% else %>
                    <%= link_to "Ingresar para reservar", new_user_session_path, class: "btn-solicitar" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>