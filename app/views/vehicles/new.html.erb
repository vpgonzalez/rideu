<nav class="navbar">
  <div class="nav-logo">
    <%= image_tag "logo.png", alt: "RideU" %>
  </div>
  <div class="nav-links">
    <%= link_to "Buscar Viaje", trips_path, class: "nav-link" %>
    <%= link_to "Publicar Ruta", new_trip_path, class: "nav-link" %>
    <%= link_to "Mi Perfil", profile_path, class: "nav-link active" %>
    <%= link_to "Cerrar sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-btn" %>
  </div>
</nav>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">🚗 Registrar Vehículo</div>
    <h2>Datos de tu auto</h2>
    <p class="auth-subtitle">Necesitas registrar tu vehículo para publicar rutas</p>

    <%= form_with model: @vehicle, url: vehicles_path, local: true do |f| %>
      <% if @vehicle.errors.any? %>
        <div class="auth-errors">
          <% @vehicle.errors.full_messages.each do |msg| %>
            <p>⚠️ <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :brand, "Marca" %>
          <%= f.text_field :brand, placeholder: "ej: Toyota", class: "form-input" %>
        </div>
        <div class="form-group">
          <%= f.label :model, "Modelo" %>
          <%= f.text_field :model, placeholder: "ej: Yaris", class: "form-input" %>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :year, "Año" %>
          <%= f.number_field :year, placeholder: "ej: 2020", class: "form-input" %>
        </div>
        <div class="form-group">
          <%= f.label :color, "Color" %>
          <%= f.text_field :color, placeholder: "ej: Azul", class: "form-input" %>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <%= f.label :plate, "Patente" %>
          <%= f.text_field :plate, placeholder: "ej: ABCD12", class: "form-input" %>
        </div>
        <div class="form-group">
          <%= f.label :seats, "Asientos disponibles" %>
          <%= f.number_field :seats, placeholder: "ej: 4", min: 1, max: 8, class: "form-input" %>
        </div>
      </div>

      <%= f.submit "Registrar vehículo", class: "btn-auth" %>
    <% end %>

    <p class="auth-footer">
      <%= link_to "← Volver al perfil", profile_path %>
    </p>
  </div>
</div>