<div class="auth-container">
  <div class="auth-card">
    <div class="auth-logo">
      <span>📍</span> RideU
    </div>
    <h2>Ingresar</h2>
    <p class="auth-subtitle">Bienvenido de vuelta</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-group">
        <%= f.label :email, "Correo" %>
        <%= f.email_field :email, placeholder: "tucorreo@gmail.com", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Contraseña" %>
        <%= f.password_field :password, placeholder: "Tu contraseña", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, "Recordarme" %>
      </div>

      <%= f.submit "Ingresar", class: "btn-auth" %>
    <% end %>

    <p class="auth-footer">
      ¿No tienes cuenta? <%= link_to "Crear cuenta", new_user_registration_path %>
    </p>
    <p class="auth-footer">
      <%= link_to "¿Olvidaste tu contraseña?", new_user_password_path %>
    </p>
  </div>
</div>